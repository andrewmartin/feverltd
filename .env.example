# ---------------------------------------------------------------------------
# Fever Ltd — environment variables
# Copy to `.env.local` and fill in. Never commit real secrets.
# ---------------------------------------------------------------------------

# Database — Neon Postgres via the Vercel Marketplace integration.
# The integration injects these (and many more) automatically per environment;
# pull them locally with `vercel env pull .env.local`. Prisma reads:
#   FEVER_POSTGRES_PRISMA_URL      pooled (pgbouncer) connection — runtime client
#   FEVER_POSTGRES_URL_NON_POOLING direct connection — migrations / db push
FEVER_POSTGRES_PRISMA_URL="postgres://user:password@host-pooler.region.aws.neon.tech/db?sslmode=require&pgbouncer=true"
FEVER_POSTGRES_URL_NON_POOLING="postgres://user:password@host.region.aws.neon.tech/db?sslmode=require"

# Auth.js / NextAuth v5
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=""
# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:7878/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Vercel Blob — image uploads for the /admin CMS. The Blob store is connected
# with a FEVER_ prefix, so the token is FEVER_READ_WRITE_TOKEN (the upload route
# reads this explicitly). Injected by Vercel; pull with `vercel env pull`.
FEVER_READ_WRITE_TOKEN=""

# Comma-separated list of emails allowed into the /admin CMS.
ADMIN_EMAILS="hello@andrewmart.in,kamtin.mohager@gmail.com"

# DEV ONLY — set "true" to bypass auth so /admin is open while building the CMS.
# Leave blank / unset in production.
ADMIN_AUTH_DISABLED=""

# Big Cartel storefront subdomain, e.g. "feverltd" for feverltd.bigcartel.com.
# Read-only public storefront JSON — no API key/OAuth required.
BIGCARTEL_STORE=

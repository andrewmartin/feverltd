# ---------------------------------------------------------------------------
# Fever Ltd — environment variables
# Copy to `.env.local` and fill in. Never commit real secrets.
# ---------------------------------------------------------------------------

# Database (PostgreSQL). On Vercel, provision Neon via the Marketplace and use
# the pooled connection string here.
DATABASE_URL="postgresql://user:password@localhost:5432/feverltd?schema=public"
# Direct (non-pooled) connection used by Prisma migrations.
DIRECT_URL="postgresql://user:password@localhost:5432/feverltd?schema=public"

# Auth.js / NextAuth v5
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=""
# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:7878/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated list of emails allowed into the /admin CMS.
ADMIN_EMAILS="hello@andrewmart.in"

// Fever Ltd — Prisma schema
// Postgres on Neon (Vercel Marketplace). The Neon integration injects the
// connection strings with a `FEVER_` prefix; `POSTGRES_PRISMA_URL` is the
// pooled (pgbouncer) URL for the client, `POSTGRES_URL_NON_POOLING` is the
// direct URL used for migrations / introspection.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("FEVER_POSTGRES_PRISMA_URL")
  directUrl = env("FEVER_POSTGRES_URL_NON_POOLING")
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth) models — required by @auth/prisma-adapter
// ---------------------------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Record label CMS models
// ---------------------------------------------------------------------------
model Artist {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  bio       String?   @db.Text
  imageUrl  String?
  website   String?
  // Many-to-many: a release can credit multiple artists (splits, comps) and an
  // artist appears on many releases. Implicit join table (_ArtistToRelease).
  releases  Release[] @relation("ArtistReleases")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum ReleaseStatus {
  DRAFT
  PUBLISHED
}

model Release {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  catalogNo   String?       @unique
  description String?       @db.Text
  coverUrl    String?
  releaseDate DateTime?
  status      ReleaseStatus @default(DRAFT)
  artists     Artist[]      @relation("ArtistReleases")
  tracks      Track[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
}

model Track {
  id        String  @id @default(cuid())
  title     String
  position  Int
  duration  Int? // seconds
  releaseId String
  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([releaseId, position])
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

// News / blog posts about the label. No owner assigned (MVP).
model NewsPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?    @db.Text
  body        String?    @db.Text
  heroImage   String?
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([publishedAt])
}
